{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@ai-desk/contracts-api": ["../../packages/contracts/api"],
      "@ai-desk/contracts-projects": ["../../packages/contracts/projects/src/index.ts"],
      "@ai-desk/contracts-runtime": ["../../packages/contracts/runtime/src/index.ts"],
      "@ai-desk/contracts-execution": ["../../packages/contracts/execution/src/index.ts"],
      "@ai-desk/ui": ["../../packages/ui/src/index.ts"]
    },
    "types": ["vitest/globals"],
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
