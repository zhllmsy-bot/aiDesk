{
  "name": "@ai-desk/web",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "prebuild": "pnpm --filter @ai-desk/ui build",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "pnpm exec biome check .",
    "pretypecheck": "pnpm --filter @ai-desk/ui build",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "pretest": "pnpm --filter @ai-desk/ui build",
    "test": "vitest run",
    "pretest:a11y": "pnpm --filter @ai-desk/ui build",
    "test:a11y": "playwright test --config playwright.config.ts --grep @a11y",
    "pretest:visual": "pnpm --filter @ai-desk/ui build",
    "test:visual": "playwright test --config playwright.config.ts --grep @visual",
    "pretest:e2e": "pnpm --filter @ai-desk/ui build",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@ai-desk/contracts-api": "workspace:*",
    "@ai-desk/contracts-execution": "workspace:*",
    "@ai-desk/contracts-projects": "workspace:*",
    "@ai-desk/contracts-runtime": "workspace:*",
    "@ai-desk/ui": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.75.7",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "tailwind-variants": "^3.2.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4.2.4",
    "vitest": "^3.2.4"
  }
}
