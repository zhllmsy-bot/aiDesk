{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      ".next",
      "dist",
      "node_modules",
      "coverage",
      "playwright-report",
      "test-results",
      "apps/api/.venv",
      "apps/api/.pytest_cache",
      "apps/api/.ruff_cache",
      "apps/worker/.venv",
      "apps/worker/.ruff_cache",
      "apps/web/.next",
      "apps/web/tsconfig.tsbuildinfo",
      "packages/contracts/api/src/generated/schema.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noConsoleLog": "error"
      }
    }
  }
}
