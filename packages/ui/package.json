{
  "name": "@ai-desk/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "default": "./dist/primitives.js"
    },
    "./manifest.json": "./manifest.json",
    "./styles.css": "./styles.css",
    "./tokens.css": "./src/tokens.css"
  },
  "files": ["dist", "manifest.json", "src", "styles.css"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "storybook": "storybook dev --config-dir ./.storybook --port 6006 --host 0.0.0.0",
    "storybook:build": "storybook build --config-dir ./.storybook --output-dir ./storybook-static",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "storybook": "10.3.5",
    "typescript": "^5.9.3",
    "vite": "8.0.10"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1"
  }
}
