{
  "name": "@ai-desk/contracts-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./generated": {
      "types": "./dist/generated/schema.d.ts",
      "default": "./dist/generated/schema.js"
    }
  },
  "files": ["dist", "src", "openapi", "README.md"],
  "scripts": {
    "generate": "pnpm exec openapi-typescript ./openapi/full.openapi.json -o ./src/generated/schema.ts",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  }
}
